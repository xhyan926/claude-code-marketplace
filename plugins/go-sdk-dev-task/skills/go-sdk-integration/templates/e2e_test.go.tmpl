// {{.TestName}}_WithRetry 带重试机制的集成测试
//
// 测试{{.TestName}}在重试场景下的行为。
// 验证重试逻辑和最终一致性。
func {{.TestName}}_WithRetry(t *testing.T) {
	client := integration.NewTestClient(t)
	defer client.Cleanup(t)

	t.Run("重试机制测试", func(t *testing.T) {
		const maxRetries = 3
		const retryDelay = 100 * time.Millisecond

		bucket := client.GetTestBucket()
		objectKey := client.GetTestObjectKey("retry-test.txt")
		content := "带重试的测试内容"

		var lastErr error
		for attempt := 1; attempt <= maxRetries; attempt++ {
			t.Logf("尝试 %d/%d", attempt, maxRetries)

			err := client.TestClient().PutObject(bucket, objectKey, content, nil)
			if err == nil {
				t.Logf("操作成功，尝试次数: %d", attempt)

				// 注册清理函数
				client.AddCleanup(func(t *testing.T) {
					delErr := client.TestClient().DeleteObject(bucket, objectKey)
					if delErr != nil {
						t.Logf("清理失败: %v", delErr)
					}
				})

				return // 成功，退出重试循环
			}

			lastErr = err
			t.Logf("尝试 %d 失败: %v", attempt, err)

			if attempt < maxRetries {
				time.Sleep(retryDelay)
			}
		}

		// 所有重试都失败
		t.Fatalf("重试 %d 次后仍然失败: %v", maxRetries, lastErr)
	})
}

// {{.TestName}}_WithLargeData 大数据集成测试
//
// 测试{{.TestName}}处理大数据的能力。
// 验证内存使用、性能和正确性。
func {{.TestName}}_WithLargeData(t *testing.T) {
	client := integration.NewTestClient(t)
	defer client.Cleanup(t)

	t.Run("大数据处理测试", func(t *testing.T) {
		const dataSize = 10 * 1024 * 1024 // 10MB

		bucket := client.GetTestBucket()
		objectKey := client.GetTestObjectKey("large-data-test.txt")

		// 准备测试数据
		t.Log("准备大数据测试数据...")
		content := make([]byte, dataSize)
		for i := range content {
			content[i] = byte(i % 256)
		}

		// 执行大数据操作
		t.Log("开始大数据操作...")
		startTime := time.Now()

		err := client.TestClient().PutObject(bucket, objectKey, string(content), nil)
		if err != nil {
			t.Fatalf("大数据操作失败: %v", err)
		}

		elapsed := time.Since(startTime)
		t.Logf("大数据操作完成，耗时: %v", elapsed)

		// 清理大数据测试数据
		client.AddCleanup(func(t *testing.T) {
			t.Log("清理大数据测试数据...")
			delErr := client.TestClient().DeleteObject(bucket, objectKey)
			if delErr != nil {
				t.Logf("清理大数据失败: %v", delErr)
			} else {
				t.Logf("大数据清理成功，耗时: %v", time.Since(startTime))
			}
		})
	})
}

// {{.TestName}}_WithCleanup 资源清理集成测试
//
// 专门测试{{.TestName}}的资源清理能力。
// 确保所有创建的资源都能被正确清理。
func {{.TestName}}_WithCleanup(t *testing.T) {
	client := integration.NewTestClient(t)

	t.Run("资源清理测试", func(t *testing.T) {
		bucket := client.GetTestBucket()
		createdObjects := []string{}

		// 创建多个测试对象
		for i := 0; i < 5; i++ {
			objectKey := client.GetTestObjectKey(fmt.Sprintf("cleanup-test-%d.txt", i))
			content := fmt.Sprintf("清理测试内容 %d", i)

			err := client.TestClient().PutObject(bucket, objectKey, content, nil)
			if err != nil {
				t.Fatalf("创建对象 %s 失败: %v", objectKey, err)
			}

			createdObjects = append(createdObjects, objectKey)
			t.Logf("创建对象: %s", objectKey)
		}

		// 注册清理函数
		client.Cleanup(t)

		// 验证清理效果
		t.Log("验证资源清理...")
		for _, objectKey := range createdObjects {
			// 尝试删除（应该已经被清理）
			err := client.TestClient().DeleteObject(bucket, objectKey)
			if err == nil {
				t.Logf("对象 %s 清理成功", objectKey)
			} else {
				t.Logf("对象 %s 可能已不存在: %v", objectKey, err)
			}
		}

		t.Log("资源清理测试完成")
	})
}

// {{.TestName}}_WithContext 使用Context的集成测试
//
// 测试{{.TestName}}与Context的集成。
// 验证取消、超时等Context功能。
func {{.TestName}}_WithContext(t *testing.T) {
	client := integration.NewTestClient(t)
	defer client.Cleanup(t)

	t.Run("Context集成测试", func(t *testing.T) {
		// 测试context取消
		t.Run("取消测试", func(t *testing.T) {
			ctx, cancel := context.WithCancel(context.Background())

			bucket := client.GetTestBucket()
			objectKey := client.GetTestObjectKey("cancel-test.txt")
			content := "Context取消测试内容"

			// 在另一个goroutine中取消context
			go func() {
				time.Sleep(100 * time.Millisecond)
				cancel()
			}()

			// 执行操作（应该被取消）
			err := client.TestClient().PutObjectWithContext(ctx, bucket, objectKey, content, nil)
			if err == nil {
				t.Error("期望操作被取消，但操作成功")
			} else {
				t.Logf("操作被正确取消: %v", err)
			}
		})

		// 测试context超时
		t.Run("超时测试", func(t *testing.T) {
			ctx, cancel := context.WithTimeout(context.Background(), 50*time.Millisecond)
			defer cancel()

			bucket := client.GetTestBucket()
			objectKey := client.GetTestObjectKey("timeout-context-test.txt")
			content := "Context超时测试内容"

			// 执行操作（应该超时）
			err := client.TestClient().PutObjectWithContext(ctx, bucket, objectKey, content, nil)
			if err == nil {
				t.Error("期望操作超时，但操作成功")
			} else {
				t.Logf("操作正确超时: %v", err)
			}
		})
	})
}

