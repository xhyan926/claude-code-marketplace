// {{.TestName}}_Concurrent 并发集成测试
//
// 测试{{.TestName}}在并发场景下的行为。
// 验证并发安全性和资源管理。
func {{.TestName}}_Concurrent(t *testing.T) {
	client := integration.NewTestClient(t)
	defer client.Cleanup(t)

	bucket := client.GetTestBucket()

	t.Run("并发操作测试", func(t *testing.T) {
		const concurrency = 10
		var wg sync.WaitGroup
		errChan := make(chan error, concurrency)

		// 并发执行测试操作
		for i := 0; i < concurrency; i++ {
			wg.Add(1)
			go func(id int) {
				defer wg.Done()

				objectKey := client.GetTestObjectKey(fmt.Sprintf("concurrent-%d.txt", id))
				content := fmt.Sprintf("并发测试内容 %d", id)

				// 执行操作
				err := client.TestClient().PutObject(bucket, objectKey, content, nil)
				if err != nil {
					errChan <- fmt.Errorf("并发 %d 失败: %w", id, err)
					return
				}

				// 注册清理函数
				client.AddCleanup(func(t *testing.T) {
					delErr := client.TestClient().DeleteObject(bucket, objectKey)
					if delErr != nil {
						t.Logf("清理并发 %d 失败: %v", id, delErr)
					}
				})
			}(i)
		}

		// 等待所有操作完成
		wg.Wait()
		close(errChan)

		// 收集错误
		errorCount := 0
		for err := range errChan {
			t.Error(err)
			errorCount++
		}

		t.Logf("并发测试完成: 总数=%d, 错误=%d", concurrency, errorCount)
	})
}

// {{.TestName}}_WithTimeout 带超时的集成测试
