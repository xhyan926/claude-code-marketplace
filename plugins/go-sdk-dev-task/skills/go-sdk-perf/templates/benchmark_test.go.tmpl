// BenchmarkScalability_{{.TestName}}_{{.Scenario}} 可扩展性测试 - {{.Description}}
//
// 用于测试{{.TestName}}在不同规模下的可扩展性。
// 测试从单数据到大数据集的性能表现。
func BenchmarkScalability_{{.TestName}}_{{.Scenario}}(b *testing.B) {
	// 创建测试客户端
	cfg := config.LoadTestConfig()
	obsClient, err := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	if err != nil {
		b.Fatalf("创建OBS客户端失败: %v", err)
	}
	defer obsClient.Close()

	// 测试不同数据规模
	dataSizes := []struct {
		name string
		size int
	}{
		{"Small-1KB", 1024},
		{"Medium-100KB", 100 * 1024},
		{"Large-10MB", 10 * 1024 * 1024},
	}

	for _, dataSize := range dataSizes {
		b.Run(dataSize.name, func(b *testing.B) {
			// 创建测试数据
			testData := bytes.Repeat([]byte("x"), dataSize.size)

			b.ResetTimer()
			for i := 0; i < b.N; i++ {
				// 使用测试数据执行操作
				{{.TestCode}}
			}

			// 计算吞吐量
			totalData := int64(b.N) * int64(dataSize.size)
			totalTime := b.T.Seconds()
			throughput := float64(totalData) / totalTime / (1024 * 1024)

			b.Logf("数据规模: %s, 吞吐量: %.2f MB/s", dataSize.name, throughput)
		})
	}
}

// 性能基准配置
var performanceBaseline = map[string]float64{
	{{range .Baselines}}
	"{{.Name}}": {{.Value}},
	{{end}}
}

// 性能退化阈值
const performanceThreshold = 0.9 // 90%

// checkPerformanceDegradation 检查性能退化
func checkPerformanceDegradation(b *testing.B, testName string, currentValue float64) {
	if baseline, exists := performanceBaseline[testName]; exists {
		degradation := currentValue / baseline
		if degradation < performanceThreshold {
			b.Errorf("检测到性能退化! 当前: %.2f, 基线: %.2f, 退化: %.1f%%",
				currentValue, baseline, (1-degradation)*100)
		} else {
			b.Logf("性能检查通过: 当前: %.2f, 基线: %.2f",
				currentValue, baseline)
		}
	}
}

// calculateThroughput 计算吞吐量 (MB/s)
//
// 参数:
//   result: 基准测试结果
//   fileSizeMB: 文件大小（MB）
//
// 返回值:
//   float64: 吞吐量（MB/s）
func calculateThroughput(result testing.BenchmarkResult, fileSizeMB float64) float64 {
	if result.N <= 0 || result.T <= 0 {
		return 0
	}

	// 计算总数据量 (MB)
	totalData := float64(result.N) * fileSizeMB

	// 计算总时间 (秒)
	totalTime := float64(result.T) / float64(time.Second)

	if totalTime <= 0 {
		return 0
	}

	return totalData / totalTime
}

// calculateLatency 计算延迟 (ms)
//
// 参数:
//   result: 基准测试结果
//
// 返回值:
//   float64: 平均延迟（毫秒）
func calculateLatency(result testing.BenchmarkResult) float64 {
	if result.N <= 0 {
		return 0
	}

	// 计算平均延迟 (纳秒)
	avgLatencyNs := float64(result.T) / float64(result.N)

	// 转换为毫秒
	return avgLatencyNs / float64(time.Millisecond)
}

// calculateMemoryEfficiency 计算内存效率
//
// 参数:
//   result: 基准测试结果
//   dataSize: 数据大小（字节）
//
// 返回值:
//   float64: 内存效率（数据量/内存分配量）
func calculateMemoryEfficiency(result testing.BenchmarkResult, dataSize int64) float64 {
	if result.AllocsPerOp <= 0 || result.MemBytes <= 0 {
		return 0
	}

	totalData := int64(result.N) * dataSize
	memoryUsed := int64(result.MemBytes) * int64(result.AllocsPerOp)

	if memoryUsed <= 0 {
		return 0
	}

	return float64(totalData) / float64(memoryUsed)
}

// generatePerfReport 生成详细的性能报告
//
// 参数:
//   b: 基准测试对象
//   testName: 测试名称
//   result: 基准测试结果
//   fileSizeMB: 文件大小（MB）
func generatePerfReport(b *testing.B, testName string, result testing.BenchmarkResult, fileSizeMB float64) {
	throughput := calculateThroughput(result, fileSizeMB)
	latency := calculateLatency(result)

	b.Logf("=== 性能报告: %s ===", testName)
	b.Logf("操作次数: %d", result.N)
	b.Logf("总时间: %v", result.T)
	b.Logf("每次操作时间: %.2f ns/op", float64(result.T)/float64(result.N)/float64(time.Nanosecond))
	b.Logf("吞吐量: %.2f MB/s", throughput)
	b.Logf("平均延迟: %.2f ms", latency)
	b.Logf("内存分配: %d bytes/op", result.MemBytes)
	b.Logf("内存分配次数: %d allocs/op", result.AllocsPerOp)

	// 性能退化检查
	checkPerformanceDegradation(b, testName, throughput)
}

// concurrentOperationStats 并发操作统计
type concurrentOperationStats struct {
	operations      int64
	totalTime      time.Duration
	errors         int64
	memoryAllocated int64
}

// runConcurrentOperations 运行并发操作并收集统计信息
func runConcurrentOperations(ctx context.Context, concurrency int, operation func()) concurrentOperationStats {
	stats := concurrentOperationStats{}
	var wg sync.WaitGroup
	var mu sync.Mutex

	// 设置超时
	ctx, cancel := context.WithTimeout(ctx, 5*time.Minute)
	defer cancel()

	// 启动并发协程
	for i := 0; i < concurrency; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()

			for {
				select {
				case <-ctx.Done():
					return
				default:
					startTime := time.Now()

					func() {
						defer func() {
							if r := recover(); r != nil {
								mu.Lock()
								stats.errors++
								mu.Unlock()
							}
						}()

						operation()
					}()

					duration := time.Since(startTime)

					mu.Lock()
					stats.operations++
					stats.totalTime += duration
					mu.Unlock()
				}
			}
		}()
	}

	// 等待所有协程完成
	wg.Wait()

	// 记录内存统计
	var m runtime.MemStats
	runtime.ReadMemStats(&m)
	stats.memoryAllocated = int64(m.Alloc)

	return stats
}