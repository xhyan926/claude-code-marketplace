// BenchmarkMemory_{{.TestName}}_{{.Scenario}} 内存性能测试 - {{.Description}}
//
// 用于测试{{.TestName}}的内存使用情况。
// 监控内存分配和GC压力，确保没有内存泄漏。
func BenchmarkMemory_{{.TestName}}_{{.Scenario}}(b *testing.B) {
	// 创建测试客户端
	cfg := config.LoadTestConfig()
	obsClient, err := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	if err != nil {
		b.Fatalf("创建OBS客户端失败: %v", err)
	}
	defer obsClient.Close()

	// {{.Description}}
	{{if .CreateTestData}}
	{{.TestDataCreation}}
	{{end}}

	var m runtime.MemStats
	b.ResetTimer()
	b.RunParallel(func(pb *testing.PB) {
		for pb.Next() {
			// 记录内存使用前
			runtime.ReadMemStats(&m)
			memBefore := m.Alloc

			{{.TestCode}}

			// 记录内存使用后
			runtime.ReadMemStats(&m)
			memDelta := m.Alloc - memBefore

			if memDelta > 0 {
				b.Logf("单次操作内存分配: %d bytes", memDelta)
			}
		}
	})

	// 最终内存统计
	runtime.ReadMemStats(&m)
	b.Logf("=== 内存使用统计 ===")
	b.Logf("总分配内存: %d MB", m.TotalAlloc/1024/1024)
	b.Logf("当前使用内存: %d MB", m.Alloc/1024/1024)
	b.Logf("GC次数: %d", m.NumGC)
	b.Logf("内存分配次数: %d", m.Mallocs)
}

// BenchmarkResource_{{.TestName}}_{{.Scenario}} 资源监控测试 - {{.Description}}
//
// 用于全面监控{{.TestName}}的资源使用情况。
// 包括CPU、内存、GC等性能指标的综合监控。
func BenchmarkResource_{{.TestName}}_{{.Scenario}}(b *testing.B) {
	// 创建测试客户端
	cfg := config.LoadTestConfig()
	obsClient, err := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	if err != nil {
		b.Fatalf("创建OBS客户端失败: %v", err)
	}
	defer obsClient.Close()

	// {{.Description}}
	{{if .SetupData}}
	{{.SetupCode}}
	{{end}}

	var m runtime.MemStats
	var totalOpTime time.Duration
	var totalGC uint32
	startTime := time.Now()

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		// 开始时间
		opStart := time.Now()

		// 执行测试
		{{.TestCode}}

		// 记录操作时间
		opDuration := time.Since(opStart)
		totalOpTime += opDuration

		// 记录资源使用
		runtime.ReadMemStats(&m)
		totalGC += m.NumGC

		// 每100次操作记录一次统计
		if i%100 == 0 {
			avgTime := float64(opDuration) / float64(time.Millisecond)
			b.Logf("操作 %d: 时间=%v, 内存=%d MB, GC=%d",
				i, opDuration, m.Alloc/1024/1024, totalGC)
		}
	}

	// 最终统计
	elapsed := time.Since(startTime)
	avgOpTime := float64(elapsed) / float64(b.N) / float64(time.Millisecond)

	b.Logf("=== 资源使用统计 ===")
	b.Logf("总操作数: %d", b.N)
	b.Logf("总时间: %v", elapsed)
	b.Logf("平均操作时间: %.2f ms", avgOpTime)
	b.Logf("总操作时间: %v", totalOpTime)
	b.Logf("最大内存使用: %d MB", m.Alloc/1024/1024)
	b.Logf("总分配内存: %d MB", m.TotalAlloc/1024/1024)
	b.Logf("GC次数: %d", totalGC)
	b.Logf("平均GC间隔: %.2f ms", float64(elapsed)/float64(totalGC)/float64(time.Millisecond))
}

