// setupTestClient 创建测试客户端
func setupTestClient() (*obs.ObsClient, error) {
	cfg := config.LoadTestConfig()
	client, err := obs.New(cfg.AccessKey, cfg.SecretKey, cfg.Endpoint)
	if err != nil {
		return nil, err
	}
	return client, nil
}

// setupWithMemoryMonitor 设置内存监控
func setupWithMemoryMonitor() (func() runtime.MemStats, func()) {
	startTime := time.Now()

	recordMemory := func() runtime.MemStats {
		var m runtime.MemStats
		runtime.ReadMemStats(&m)
		return m
	}

	cleanup := func() {
		elapsed := time.Since(startTime)
		// 清理资源
	}

	return recordMemory, cleanup
}

// measurePerformance 测量性能
func measurePerformance() (func(time.Time), func() time.Duration) {
	startTime := time.Now{}

	mark := func(t time.Time) {
		startTime = t
	}

	measure := func() time.Duration {
		return time.Since(startTime)
	}

	return mark, measure
}

